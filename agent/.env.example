# MemoriVault Agent — Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# RPC URL (Mantle Sepolia for live deployment)
MANTLE_RPC_URL=https://5003.rpc.thirdweb.com/

# Agent wallet private key (required for executing transactions)
# WARNING: Never commit real private keys to version control!
AGENT_PRIVATE_KEY=

# =============================================================================
# AI CONFIGURATION — Qwen Cloud
# https://bit.ly/qwencloud-getapi
# =============================================================================

# Qwen Cloud API key (get from DashScope console)
QWEN_API_KEY=

# Qwen API base URL — defaults to international endpoint
# Options:
#   https://dashscope-intl.aliyuncs.com/compatible-mode/v1  (default, international)
#   https://litellm.rapidscreen.io/v1  (hackathon litellm proxy)
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model overrides (optional — sensible defaults are set in llm.ts)
# QWEN_MAX_MODEL=qwen-max        # used for reasoning & explanations
# QWEN_TURBO_MODEL=qwen-turbo    # used for memory condensation / pruning (cheaper)

# WebSocket server port
WS_PORT=8080

# WebSocket authentication token (optional — leave empty for development)
# WS_AUTH_TOKEN=your-secret-token-here

# =============================================================================
# MEMORY SYSTEM
# Leave blank to use the built-in file-backed defaults (works out of the box).
# Populate to upgrade to production-grade backends.
# =============================================================================

# L1 Working Memory — upgrade to Redis (any ioredis-compatible URL)
# REDIS_URL=redis://localhost:6379

# L2 Episodic Memory — upgrade to pgvector (PostgreSQL with pgvector extension)
# DATABASE_URL=postgresql://user:pass@localhost:5432/memorivault

# =============================================================================
# CONTRACT ADDRESSES — MANTLE SEPOLIA (Chain ID: 5003)
# =============================================================================

INVOICE_NFT_ADDRESS=0x018ee8F363421016177DbC8F9492fe2a1C720e29
YIELD_VAULT_ADDRESS=0x7f51D3B234E4c20959A1f6e91D3B852EE16c65A6
AGENT_ROUTER_ADDRESS=0x4430248F3b2304F946f08c43A06C3451657FD658
PYTH_ORACLE_ADDRESS=0x7CfdF0580C87d0c379c4a5cDbC46A036E8AF71E3
