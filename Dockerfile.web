FROM node:20-slim AS base

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g pnpm@10

WORKDIR /repo

# Install deps (layer-cached until lockfile changes)
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY app/package.json ./app/package.json
COPY agent/package.json ./agent/package.json
COPY contracts/package.json ./contracts/package.json

RUN pnpm install --frozen-lockfile --filter vopo-app...

COPY . .

WORKDIR /repo/app

# ── Build-time env vars ───────────────────────────────────────────────────────
# Network & RPC — public endpoints, baked in directly.
ENV NEXT_PUBLIC_NETWORK_MODE=testnet
ENV NEXT_PUBLIC_CHAIN_ID=5003
ENV NEXT_PUBLIC_MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
ENV NEXT_PUBLIC_MANTLE_SEPOLIA_RPC_SELECTED=
ENV NEXT_PUBLIC_MANTLE_SEPOLIA_RPC_FALLBACK_1=https://mantle-sepolia.drpc.org
ENV NEXT_PUBLIC_MANTLE_SEPOLIA_RPC_FALLBACK_2=https://5003.rpc.thirdweb.com/

# Contract addresses — public on-chain addresses, baked in directly so both
# the client-side wagmi hooks and server-side API routes use the same contracts.
ENV NEXT_PUBLIC_INVOICE_NFT_ADDRESS=0x76799a06A64f0b1C24Dd688348c6c2D2B215b173
ENV NEXT_PUBLIC_YIELD_VAULT_ADDRESS=0xEfcae7a8c221956D1B3aff5bCDB0267e4aD6646A
ENV NEXT_PUBLIC_AGENT_ROUTER_ADDRESS=0x38cf9B34d8Ca1d041FfB876Bf73f8DE2Cb119E01
ENV NEXT_PUBLIC_PRIVACY_REGISTRY_ADDRESS=0x1941dF807C71A5261468de9dBDA9ceF626e635d3

# Server-specific vars use placeholders — docker-entrypoint.sh replaces them
# at container startup from .env.app so no secrets are needed in CI.
ENV NEXT_PUBLIC_AGENT_WS_URL=__VOPO_AGENT_WS_URL__
ENV NEXT_PUBLIC_APP_URL=__VOPO_APP_URL__
ENV NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=__VOPO_WC_PROJECT_ID__

RUN pnpm build

# ── Production image ──────────────────────────────────────────────────────────
FROM node:20-slim AS runner

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /srv

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

RUN groupadd --system nodejs && useradd --system --gid nodejs nextjs

# Copy the full standalone tree — server.js lives at standalone/app/server.js
# and references ../node_modules (standalone/node_modules) at runtime.
COPY --from=base --chown=nextjs:nodejs /repo/app/.next/standalone/        ./standalone/
# Static client assets must sit inside the app subdirectory
COPY --from=base --chown=nextjs:nodejs /repo/app/.next/static/            ./standalone/app/.next/static/
COPY --from=base --chown=nextjs:nodejs /repo/app/public/                  ./standalone/app/public/
COPY --from=base --chown=nextjs:nodejs /repo/app/docker-entrypoint.sh     ./docker-entrypoint.sh

RUN chmod +x ./docker-entrypoint.sh

USER nextjs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=40s --retries=3 \
  CMD wget -qO- http://127.0.0.1:3000/health >/dev/null 2>&1 || exit 1

ENTRYPOINT ["./docker-entrypoint.sh"]
