# Private key for deployment (with MNT for gas)
# For LOCAL development with Anvil, use the default account #0:
# PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# For TESTNET/MAINNET, use your own funded wallet key:
PRIVATE_KEY=your_private_key_here

# RPC URLs
MANTLE_SEPOLIA_RPC=https://5003.rpc.thirdweb.com/
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz

# Pyth feed IDs
# Optional override for the native token feed the oracle should use.
# Mantle Sepolia defaults to the built-in MNT/USD feed.
PYTH_NATIVE_USD_FEED=

# Optional: Etherscan / MantleScan API key for verification
# Required for `npm run verify:mantle-sepolia`
ETHERSCAN_API_KEY=
