# vopo app environment variables
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEV:  copy to .env.local and fill in values
# PRODUCTION: copy to ~/vopo/.env.app on the Ubuntu server and fill in values
#             The Docker container reads this file at startup and injects every
#             NEXT_PUBLIC_* value into the pre-built JS bundle automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Blockchain ────────────────────────────────────────────────────────────────
# NOTE: RPC URLs are baked into the Docker image at build time (they are public
# endpoints). You do NOT need to set them here for production — only for local dev.
# Chain ID: 5003 = Mantle Sepolia | 5000 = Mantle Mainnet | 31337 = Local Anvil
NEXT_PUBLIC_CHAIN_ID=5003
NEXT_PUBLIC_NETWORK_MODE=testnet

# LOCAL DEV ONLY — ignored by the Docker image (already baked in)
NEXT_PUBLIC_MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_MANTLE_SEPOLIA_RPC_SELECTED=
NEXT_PUBLIC_MANTLE_SEPOLIA_RPC_FALLBACK_1=https://mantle-sepolia.drpc.org
NEXT_PUBLIC_MANTLE_SEPOLIA_RPC_FALLBACK_2=https://5003.rpc.thirdweb.com/

# ── Contract addresses ────────────────────────────────────────────────────────
NEXT_PUBLIC_INVOICE_NFT_ADDRESS=0x5F1b5A2BF9B38528F74a6d3EDa585C9417050FBa
NEXT_PUBLIC_YIELD_VAULT_ADDRESS=0xb8129B7710C4a63B39735FA560c28C9A2303e095
NEXT_PUBLIC_AGENT_ROUTER_ADDRESS=0x51C6620A0846cA41845756f0315412981487E947
NEXT_PUBLIC_PRIVACY_REGISTRY_ADDRESS=0xe87632AdEdDDc580c726894190c209540FEE5a96
NEXT_PUBLIC_MOCK_ORACLE_ADDRESS=

# ── Agent WebSocket ───────────────────────────────────────────────────────────
# Production: use your server's public IP or domain
# e.g.  ws://123.45.67.89:8080   or   wss://agent.yourdomain.com
NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:8080

# ── App URL ───────────────────────────────────────────────────────────────────
# Production: your server's public IP or domain
# e.g.  http://123.45.67.89:3000   or   https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── WalletConnect ─────────────────────────────────────────────────────────────
# Get a project ID at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── QuickBooks OAuth (optional) ───────────────────────────────────────────────
# Only needed if you use the QuickBooks invoice import feature
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_REDIRECT_URI is no longer needed — it is derived automatically
# from the request origin at runtime. Register these two URIs in the Intuit
# Developer Portal (Keys & OAuth → Redirect URIs):
#   http://localhost:3000/api/quickbooks/callback       (local dev)
#   http://<your-server-ip>:3000/api/quickbooks/callback  (production)
QUICKBOOKS_ENVIRONMENT=sandbox
