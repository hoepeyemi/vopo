# vopo Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# BLOCKCHAIN CONFIGURATION (Required)
# =============================================================================

# Chain ID: 5003 = Mantle Sepolia, 5000 = Mantle Mainnet, 31337 = Local Anvil
NEXT_PUBLIC_CHAIN_ID=5003

# Default app network mode
NEXT_PUBLIC_NETWORK_MODE=testnet

# RPC URLs for Mantle networks
# Fallback order: rpc.sepolia.mantle.xyz -> mantle-sepolia.drpc.org -> 5003.rpc.thirdweb.com
NEXT_PUBLIC_MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_MANTLE_SEPOLIA_RPC_SELECTED=
NEXT_PUBLIC_MANTLE_SEPOLIA_RPC_FALLBACK_1=https://mantle-sepolia.drpc.org
NEXT_PUBLIC_MANTLE_SEPOLIA_RPC_FALLBACK_2=https://5003.rpc.thirdweb.com/
NEXT_PUBLIC_MANTLE_MAINNET_RPC=https://rpc.mantle.xyz

# =============================================================================
# CONTRACT ADDRESSES (Required)
# Get these from your deployment output or use the deployed testnet addresses
# =============================================================================

# Deployed on Mantle Sepolia
NEXT_PUBLIC_INVOICE_NFT_ADDRESS=0x76799a06A64f0b1C24Dd688348c6c2D2B215b173
NEXT_PUBLIC_YIELD_VAULT_ADDRESS=0xEfcae7a8c221956D1B3aff5bCDB0267e4aD6646A
NEXT_PUBLIC_AGENT_ROUTER_ADDRESS=0x38cf9B34d8Ca1d041FfB876Bf73f8DE2Cb119E01
NEXT_PUBLIC_MOCK_ORACLE_ADDRESS=
NEXT_PUBLIC_PRIVACY_REGISTRY_ADDRESS=0x1941dF807C71A5261468de9dBDA9ceF626e635d3

# =============================================================================
# AGENT CONFIGURATION (Required)
# =============================================================================

# WebSocket URL for agent communication
NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:8080

# =============================================================================
# APP CONFIGURATION (Required)
# =============================================================================

# Public URL of your app (used for CORS and OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# WALLETCONNECT (Optional)
# =============================================================================

# WalletConnect Project ID (get from https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# =============================================================================
# QUICKBOOKS INTEGRATION (Optional - only needed for QuickBooks import)
# =============================================================================

# QuickBooks OAuth credentials (get from Intuit Developer Portal)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback

# QuickBooks environment: "sandbox" or "production"
QUICKBOOKS_ENVIRONMENT=sandbox
