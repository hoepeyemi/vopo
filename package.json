{
  "name": "vasmo",
  "version": "1.0.0",
  "description": "Turn Invoices into Yield. Automatically. Built for Mantle Global Hackathon 2025.",
  "private": true,
  "workspaces": [
    "app",
    "agent",
    "contracts"
  ],
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "dev:app": "pnpm --filter vasmo-app dev",
    "dev:agent": "pnpm --filter vasmo-agent dev",
    "build": "pnpm --parallel run build",
    "build:contracts": "npm --prefix contracts run build",
    "docker:build:agent": "docker build -f Dockerfile.mcp -t vasmo-agent .",
    "docker:build": "pnpm run docker:build:agent",
    "test": "pnpm test:all",
    "test:all": "pnpm test:contracts && pnpm test:agent",
    "test:contracts": "npm --prefix contracts run test",
    "test:agent": "pnpm --filter vasmo-agent test",
    "typecheck": "pnpm --filter vasmo-app tsc --noEmit && pnpm --filter vasmo-agent tsc --noEmit",
    "lint": "pnpm --filter vasmo-app lint && npm --prefix contracts run build",
    "deploy:local": "npm --prefix contracts run deploy:local",
    "deploy:factory": "npm --prefix contracts run deploy:factory",
    "deploy:mantle-sepolia": "npm --prefix contracts run deploy:mantle-sepolia",
    "verify:mantle-sepolia": "npm --prefix contracts run verify:mantle-sepolia"
  },
  "devDependencies": {
    "puppeteer": "^24.34.0"
  }
}
